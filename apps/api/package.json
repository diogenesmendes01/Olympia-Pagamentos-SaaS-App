{
  "name": "@olympia/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=../../.env watch src/server.ts",
    "dev:worker": "tsx --env-file=../../.env watch src/worker.ts",
    "build": "tsc",
    "start": "node --env-file=../../.env dist/server.js",
    "start:worker": "node --env-file=../../.env dist/worker.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=../../.env src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@olympia/shared": "workspace:*",
    "better-auth": "^1.2.0",
    "bullmq": "^5.25.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.0",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@olympia/tsconfig": "workspace:*",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9",
    "globals": "^17.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
